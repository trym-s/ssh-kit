# Arch-only pacman helpers — defined only on hosts that actually have pacman.
if command -v pacman >/dev/null; then
  __pacman_clear_stale_lock() {
    local lock=/var/lib/pacman/db.lck

    [[ -e "$lock" ]] || return 0

    if sudo fuser "$lock" >/dev/null 2>&1 || sudo lsof "$lock" >/dev/null 2>&1; then
      echo "pacman database lock is active: $lock" >&2
      echo "Another package manager appears to be running; not removing the lock." >&2
      return 1
    fi

    echo "Removing stale pacman database lock: $lock" >&2
    sudo rm -f "$lock"
  }

  sp() {
    __pacman_clear_stale_lock || return
    sudo pacman "$@"
  }
  alias pacup="sp -Syu"
  alias cleanup='sudo pacman -Rns $(pacman -Qtdq)'
fi
alias bd='bg && disown'
alias disk='df -B1 --total -x tmpfs -x devtmpfs -x squashfs -x overlay -x efivarfs 2>/dev/null | awk '\''/^total/{printf "Total: %.2f GB\nUsed:  %.2f GB\nFree:  %.2f GB\n", $2/1073741824, $3/1073741824, $4/1073741824}'\'''

